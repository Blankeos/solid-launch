{
  "name": "solid-launch",
  "version": "0.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vike dev",
    "dev:services": "docker compose -f docker-compose.dev.yml up -d",
    "build": "bunx --bun vike build",
    "preview": "NODE_ENV=production bun run dist/server/index.mjs",
    "preview-static": "vike preview",
    "typecheck": "tsc --noemit",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "cleanmods": "rm -rf node_modules",
    "db:generate": "bunx prisma generate && prisma migrate dev --create-only",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "apigen": "bunx rollup --config apigen/rollup.config.cjs --bundleConfigAsCjs",
    "update": "bunx npm-check-updates --interactive --format group",
    "icon": "iconmate --folder src/assets/icons/"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.36.2",
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.1",
    "@atlaskit/pragmatic-drag-and-drop-auto-scroll": "^2.1.5",
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "@bprogress/core": "^1.3.4",
    "@corvu/drawer": "^0.2.4",
    "@hono/standard-validator": "^0.2.2",
    "@kobalte/core": "^0.13.11",
    "@libsql/kysely-libsql": "^0.4.1",
    "@node-rs/argon2": "^2.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "@vikejs/hono": "^0.2.1",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/solid-form": "^1.29.1",
    "@tanstack/solid-query": "^5.100.9",
    "@tanstack/solid-table": "^8.21.3",
    "arctic": "^3.7.0",
    "bagon-hooks": "^0.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk-solid": "^1.1.2",
    "dayjs": "^1.11.20",
    "dodopayments": "^2.31.0",
    "hono": "^4.12.27",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3",
    "kysely": "^0.28.17",
    "kysely-bun-worker": "^1.2.1",
    "prisma": "^7.8.0",
    "prisma-kysely": "^3.1.0",
    "solid-js": "1.9.13",
    "solid-resizable-panels": "^0.5.4",
    "solid-sonner": "^0.3.1",
    "solid-transition-group": "^0.3.0",
    "standardwebhooks": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tippy.js": "^6.3.7",
    "vike": "^0.4.260",
    "vike-metadata-solid": "^1.0.5",
    "vike-solid": "^0.8.3",
    "zeptomail": "^7.0.2",
    "zod": "^4.4.3",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@blankeos/vike-routegen": "^0.0.3",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/solid-query-devtools": "^5.100.9",
    "@types/bun": "^1.3.14",
    "dotenv": "^17.4.2",
    "iconmate": "^1.2.0",
    "postcss": "^8.5.14",
    "rollup-plugin-dts": "^6.4.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12",
    "vite-plugin-solid-svg": "^0.8.1"
  }
